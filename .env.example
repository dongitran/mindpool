# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Replace with your actual API keys before running
KIMI_API_KEY=your-kimi-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here

# ── LLM Routing ───────────────────────────────────────────────────────────────
# Provider for main agent responses
LLM_FULL_RESPONSE_PROVIDER=kimi
LLM_FULL_RESPONSE_MODEL=kimi-k2.5

# Provider for relevance checks (lighter/faster)
LLM_RELEVANCE_CHECK_PROVIDER=kimi
LLM_RELEVANCE_CHECK_MODEL=kimi-k2.5

# Provider for recap synthesis
LLM_RECAP_SYNTHESIS_PROVIDER=kimi
LLM_RECAP_SYNTHESIS_MODEL=kimi-k2.5

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# For local dev (without Docker): point to localhost
# Docker Compose overrides these automatically via environment block
MONGO_URI=mongodb://localhost:27017/mindpool
REDIS_URL=redis://localhost:6379

# ── Observability ──────────────────────────────────────────────────────────────
# Set to true to persist structured per-meeting events to MongoDB (MeetingLog collection).
# Query all logs for a meeting: db.meetinglogs.find({ poolId: "<id>" }).sort({ createdAt: 1 })
LOGS_MEETING_ENABLE=true
